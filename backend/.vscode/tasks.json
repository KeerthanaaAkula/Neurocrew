{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven clean package",
      "type": "shell",
      "command": "mvn",
      "args": ["clean", "package", "-DskipTests"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$javaexception"
      ],
      "presentation": {
        "clear": true,
        "reveal": "always"
      }
    },
    {
      "label": "Run Spring Boot App (after build)",
      "type": "shell",
      "command": "java",
      "args": ["-jar", "target/neurocrew-backend-1.0.0.jar"],
      "isBackground": false,
      "problemMatcher": []
    }
  ]
}
